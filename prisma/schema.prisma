generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeadSource {
  WEBSITE
  REFERRAL
  PAID_ADS
  ORGANIC
  OTHER
}

enum LeadStatus {
  PENDING
  ENRICHING
  ENRICHED
  CLASSIFYING
  CLASSIFIED
  FAILED
}

enum ProcessingStatus {
  SUCCESS
  FAILED
}

enum Classification {
  Hot
  Warm
  Cold
}

enum CommercialPotential {
  High
  Medium
  Low
}

model Lead {
  id              String     @id @default(uuid())
  fullName        String     @db.VarChar(100)
  email           String     @unique
  phone           String
  companyName     String     @db.VarChar(150)
  companyCnpj    String     @unique @db.VarChar(14)
  companyWebsite  String?
  estimatedValue  Decimal?   @db.Decimal(15, 2)
  source          LeadSource
  notes           String?    @db.VarChar(500)
  status          LeadStatus @default(PENDING)

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  enrichments     Enrichment[]
  classifications AiClassification[]

  @@map("leads")
}

model Enrichment {
  id              String           @id @default(uuid())
  leadId          String
  lead            Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)

  companyName     String?
  tradeName       String?
  cnpj            String?
  industry        String?
  legalNature     String?
  employeeCount   Int?
  annualRevenue   Decimal?         @db.Decimal(15, 2)
  foundedAt       DateTime?
  address         Json?
  cnaes           Json?
  partners        Json?
  phones          Json?
  emails          Json?

  requestedAt     DateTime
  completedAt     DateTime?
  status          ProcessingStatus
  errorMessage    String?

  createdAt       DateTime         @default(now())

  @@index([leadId])
  @@map("enrichments")
}

model AiClassification {
  id                  String              @id @default(uuid())
  leadId              String
  lead                Lead                @relation(fields: [leadId], references: [id], onDelete: Cascade)

  score               Int?
  classification      Classification?
  justification       String?
  commercialPotential CommercialPotential?
  modelUsed           String?

  requestedAt         DateTime
  completedAt         DateTime?
  status              ProcessingStatus
  errorMessage        String?

  createdAt           DateTime            @default(now())

  @@index([leadId])
  @@map("ai_classifications")
}
